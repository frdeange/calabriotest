# ============================================================
# OPTION2: Direct Client with Local Tools
# ============================================================
# This configuration is for running agents using 
# AzureOpenAIChatClient.as_agent() with tools executing locally.
# ============================================================

# ------------------------------------------------------------
# Azure OpenAI Configuration
# ------------------------------------------------------------
# Your Azure OpenAI resource endpoint
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Model deployment name (we're using gpt-5.2)
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.2

# API version (use latest stable)
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ------------------------------------------------------------
# Authentication
# ------------------------------------------------------------
# Option 1: Azure CLI (recommended for local dev)
# Just run: az login
# No additional config needed!

# Option 2: Service Principal (for production/CI)
# Uncomment and fill these:
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_TENANT_ID=your-tenant-id

# ------------------------------------------------------------
# Logging & Metrics
# ------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Metrics output: console
METRICS_OUTPUT=console
