# ============================================================
# OPTION1: Agent Service + MCP Server
# ============================================================
# This configuration is for running agents using 
# AzureAIProjectAgentProvider with HostedMCPTool connecting
# to an external MCP server for tool execution.
# ============================================================

# ------------------------------------------------------------
# Azure OpenAI Configuration
# ------------------------------------------------------------

# Model deployment name (we're using gpt-5.2)
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.2-chat

# API version (use latest stable)
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ------------------------------------------------------------
# Azure AI Foundry Project (Required for Agent Service)
# ------------------------------------------------------------
# Your AI Foundry project endpoint
AZURE_AI_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/

# ------------------------------------------------------------
# MCP Server Configuration
# ------------------------------------------------------------
# Host where MCP server is running
MCP_SERVER_HOST=localhost

# Port for MCP server
MCP_SERVER_PORT=8080

# Full MCP endpoint URL (constructed from above or override)
MCP_SERVER_URL=http://localhost:8080/mcp

# ------------------------------------------------------------
# Authentication
# ------------------------------------------------------------
# Option 1: Azure CLI (recommended for local dev)
# Just run: az login
# No additional config needed!

# Option 2: Service Principal (for production/CI)
# Uncomment and fill these:
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_TENANT_ID=your-tenant-id

# ------------------------------------------------------------
# Logging & Metrics
# ------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Metrics output: console
METRICS_OUTPUT=console
